{%- comment -%}
  Reusable product card snippet
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

<div class="catalog-card hover-lift" data-product-card>
  {%- if product.metafields.custom.badge != blank -%}
    <span class="catalog-badge badge-{{ product.metafields.custom.badge | downcase }}">{{ product.metafields.custom.badge }}</span>
  {%- elsif product.tags contains 'terlaris' -%}
    <span class="catalog-badge badge-terlaris">Terlaris</span>
  {%- elsif product.tags contains 'promo' -%}
    <span class="catalog-badge badge-promo">Promo</span>
  {%- elsif product.tags contains 'terbaru' -%}
    <span class="catalog-badge badge-terbaru">Terbaru</span>
  {%- endif -%}

  <a href="{{ product.url }}" class="catalog-img">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy" width="300" height="300">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </a>

  <div class="catalog-info">
    <span class="catalog-category">{{ product.type }}</span>
    <h4><a href="{{ product.url }}" style="text-decoration:none;color:inherit">{{ product.title }}</a></h4>
    <div class="catalog-price-row">
      <span class="catalog-price">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="catalog-price-original">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    {%- if product.available -%}
      <form action="/cart/add" method="post">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="btn btn-outline btn-sm catalog-btn" data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}">
          {{ 'product.add_button' | t }}
        </button>
      </form>
    {%- else -%}
      <button class="btn btn-outline btn-sm catalog-btn" disabled>Habis</button>
    {%- endif -%}
  </div>
</div>
