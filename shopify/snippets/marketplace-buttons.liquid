{%- comment -%}
  Marketplace buttons snippet
  Usage: {% render 'marketplace-buttons', size: 'small' %}
         {% render 'marketplace-buttons', size: 'medium' %}
{%- endcomment -%}

{%- assign btn_class = 'mp-link' -%}
{%- assign icon_size = 11 -%}
{%- if size == 'medium' -%}
  {%- assign btn_class = 'mp-strip-btn' -%}
  {%- assign icon_size = 16 -%}
{%- elsif size == 'product-detail' -%}
  {%- assign btn_class = 'pd-mp-btn' -%}
  {%- assign icon_size = 14 -%}
{%- endif -%}

{%- if settings.shopee_url != blank -%}
  <a href="{{ settings.shopee_url }}" target="_blank" rel="noopener noreferrer" class="{{ btn_class }} {% if size == 'medium' %}mp-strip-shopee{% elsif size == 'product-detail' %}pd-mp-shopee{% else %}mp-shopee{% endif %}">
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 48 48" fill="white"><path d="M24 4c-3.87 0-7 3.13-7 7h3c0-2.21 1.79-4 4-4s4 1.79 4 4h3c0-3.87-3.13-7-7-7zM8 14L4 44h40L40 14H8zm16 22c-5.52 0-10-4.48-10-10h3c0 3.87 3.13 7 7 7s7-3.13 7-7h3c0 5.52-4.48 10-10 10z"/></svg>
    Shopee
  </a>
{%- endif -%}

{%- if settings.tokopedia_url != blank -%}
