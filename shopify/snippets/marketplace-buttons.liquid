    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 48 48" fill="white"><path d="M24 2C12.95 2 4 10.95 4 22c0 11.05 8.95 20 20 20s20-8.95 20-20C44 10.95 35.05 2 24 2zm0 36c-8.84 0-16-7.16-16-16S15.16 6 24 6s16 7.16 16 16-7.16 16-16 16zm-6-18c0-1.66 1.34-3 3-3s3 1.34 3 3v8h-6v-8zm12 0c0-1.66 1.34-3 3-3s3 1.34 3 3v8h-6v-8zM24 8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
    Tokopedia
  </a>
{%- endif -%}

