{%- comment -%} WhatsApp Floating Button {%- endcomment -%}

<div class="wa-float">
  <span class="wa-tooltip">Hubungi via WhatsApp</span>
  <a
    href="https://wa.me/{{ settings.whatsapp_number | default: '6281234567890' }}?text={{ settings.whatsapp_message | default: 'Halo Montana! Saya tertarik dengan produk Anda.' | url_encode }}"
    target="_blank"
    rel="noopener noreferrer"
    class="wa-float-btn"
    aria-label="Chat via WhatsApp"
  >
    {% render 'svg-icons', icon: 'whatsapp' %}
  </a>
</div>
