<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <title>{{ page_title }} — {{ shop.name }}</title>
    <meta name="description" content="{{ page_description | default: shop.description }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
    {%- endif -%}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}
  </head>
  <body>
    {%- section 'announcement-bar' -%}
    {%- section 'header' -%}

    {% render 'cart-drawer' %}

    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {%- section 'footer' -%}

    {%- if settings.whatsapp_float_enabled -%}
      {% render 'whatsapp-float' %}
    {%- endif -%}

    {% render 'product-detail-modal' %}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
