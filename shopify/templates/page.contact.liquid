{%- comment -%} Contact Page Template — replaces Contact.jsx {%- endcomment -%}
<main class="contact-page">

  {%- comment -%} Hero {%- endcomment -%}
  <section class="contact-hero">
    <div class="container text-center">
      <span class="section-label">{{ 'contact.title' | t }}</span>
      <h1>{{ 'contact.title' | t }}</h1>
      <p class="contact-hero-sub">Kami senang mendengar dari Anda. Kirimkan pertanyaan, saran, atau ajuan kerjasama melalui formulir di bawah ini.</p>
    </div>
  </section>

  {%- comment -%} Contact Content {%- endcomment -%}
  <section class="section">
    <div class="container contact-grid">

      {%- comment -%} Contact Form {%- endcomment -%}
      <div class="contact-form-wrap">
        <h2 class="mb-3">{{ 'contact.send_message' | t }}</h2>
        <form class="contact-form" action="https://wa.me/{{ settings.whatsapp_number }}" method="get" target="_blank" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="contact-name">{{ 'contact.name' | t }}</label>
              <input type="text" id="contact-name" name="name" placeholder="Masukkan nama Anda" required>
            </div>
            <div class="form-group">
              <label for="contact-email">{{ 'contact.email' | t }}</label>
              <input type="email" id="contact-email" name="email" placeholder="Masukkan email Anda" required>
            </div>
          </div>
          <div class="form-group">
            <label for="contact-subject">{{ 'contact.subject' | t }}</label>
            <input type="text" id="contact-subject" name="subject" placeholder="Tentang apa pesan Anda?">
          </div>
          <div class="form-group">
            <label for="contact-message">{{ 'contact.message' | t }}</label>
            <textarea id="contact-message" name="message" rows="5" placeholder="Tuliskan pesan Anda di sini..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg" style="width:100%">
            {% render 'svg-icons', icon: 'arrow-right', size: 16 %}
            {{ 'contact.send_wa' | t }}
          </button>
        </form>
      </div>

      {%- comment -%} Contact Info {%- endcomment -%}
      <div class="contact-info">
        <h2 class="mb-3">{{ 'contact.info_title' | t }}</h2>
        <div class="contact-info-card">
          <div class="info-block">
            <div class="info-icon-wrap">{% render 'svg-icons', icon: 'whatsapp', size: 20 %}</div>
            <div><h4>WhatsApp</h4><p>+62 812 3456 7890</p></div>
          </div>
          <div class="info-block">
            <div class="info-icon-wrap">{% render 'svg-icons', icon: 'arrow-right', size: 20 %}</div>
            <div><h4>Email</h4><p>admin@montanastationery.com</p></div>
          </div>
          <div class="info-block">
            <div class="info-icon-wrap">{% render 'svg-icons', icon: 'shield-check', size: 20 %}</div>
            <div><h4>{{ 'contact.hours' | t }}</h4><p>{{ 'contact.hours_value' | t }}</p></div>
          </div>
          <div class="info-block">
            <div class="info-icon-wrap">{% render 'svg-icons', icon: 'arrow-right', size: 20 %}</div>
            <div><h4>{{ 'contact.location' | t }}</h4><p>{{ 'contact.location_value' | t }}</p></div>
          </div>
        </div>

        <div class="bulk-order-card">
          <h4>{{ 'contact.bulk_title' | t }}</h4>
          <p>{{ 'contact.bulk_desc' | t }}</p>
          <button class="btn btn-outline btn-sm" style="width:100%">{{ 'contact.download_catalog' | t }}</button>
        </div>
      </div>
    </div>
  </section>
</main>
