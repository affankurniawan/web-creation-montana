{%- comment -%} Blog Template — replaces Blog.jsx {%- endcomment -%}
<main class="blog-page">

  {%- comment -%} Hero {%- endcomment -%}
  <section class="blog-hero">
    <div class="container text-center">
      <span class="section-label">Blog</span>
      <h1>Jurnal Montana</h1>
      <p class="blog-hero-sub">Temukan wawasan terbaru, tips produktivitas, dan pembaruan inovatif seputar dunia alat tulis dan kebutuhan kantor.</p>
    </div>
  </section>

  {%- comment -%} Articles {%- endcomment -%}
  <section class="section">
    <div class="container">
      <div class="blog-grid stagger-children">
        {%- paginate blog.articles by 9 -%}
          {%- for article in blog.articles -%}
            <article class="blog-card hover-lift">
              <div class="blog-img-wrapper">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title }}" loading="lazy">
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag }}
                {%- endif -%}
                {%- if article.tags.size > 0 -%}
                  <span class="blog-category-badge">{{ article.tags.first }}</span>
                {%- endif -%}
              </div>

              <div class="blog-content">
                <div class="blog-meta">
                  <span>{{ article.published_at | date: '%d %b %Y' }}</span>
                  <span class="blog-dot">·</span>
                  <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} menit</span>
                </div>

                <h2 class="blog-title">
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h2>

                <p class="blog-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 160 }}</p>

                <a href="{{ article.url }}" class="blog-read-more">
                  Baca Selengkapnya
                  {% render 'svg-icons', icon: 'arrow-right', size: 14 %}
                </a>
              </div>
            </article>
          {%- endfor -%}
        {%- endpaginate -%}
      </div>

      {%- paginate blog.articles by 9 -%}
        {%- if paginate.pages > 1 -%}
          <div class="pagination" style="margin-top:var(--spacing-2xl)">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="page-btn">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="page-btn active">{{ part.title }}</span>
              {%- else -%}
                <span class="page-btn">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </section>
</main>
