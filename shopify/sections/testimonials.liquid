<section class="section bg-off-white">
  <div class="container">
    <div class="section-intro text-center mb-5">
      <span class="section-label">{{ section.settings.label }}</span>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="grid grid-cols-3 gap-3 stagger-children">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="stars">
            {%- for i in (1..5) -%}
              {% render 'svg-icons', icon: 'star', size: 14 %}
            {%- endfor -%}
          </div>
          <p>"{{ block.settings.quote }}"</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">{{ block.settings.author | slice: 0 }}</div>
            <div>
              <strong>{{ block.settings.author }}</strong>
              <span>{{ block.settings.role }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Testimoni" },
    { "type": "text", "id": "heading", "label": "Judul", "default": "Kata Mereka" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimoni",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Kutipan", "default": "Akhirnya ada pena yang tintanya tidak tembus dan tahan satu semester." },
        { "type": "text", "id": "author", "label": "Nama", "default": "Ayu T." },
        { "type": "text", "id": "role", "label": "Peran", "default": "Mahasiswa" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "testimonial", "settings": { "quote": "Akhirnya ada pena yang tintanya tidak tembus dan tahan satu semester. Sangat sepadan.", "author": "Ayu T.", "role": "Mahasiswa" } },
      { "type": "testimonial", "settings": { "quote": "Kami melengkapi seluruh kantor dengan Montana. Terlihat premium tanpa bikin kantong jebol.", "author": "Budi P.", "role": "Manajer Kantor" } },
      { "type": "testimonial", "settings": { "quote": "Sempurna untuk perlengkapan sekolah anak-anak. Cukup awet untuk dipakai setahun penuh.", "author": "Siti K.", "role": "Ibu" } }
    ]
  }
}
{% endschema %}
