<footer class="footer bg-black">
  <div class="container footer-container">
    {%- comment -%} Brand + Social {%- endcomment -%}
    <div class="footer-brand">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: height: 40 }}" alt="{{ shop.name }}" style="height:40px">
      {%- else -%}
        <img src="{{ 'logo.png' | asset_url }}" alt="Montana" style="height:40px">
      {%- endif -%}
      <p>{{ 'footer.tagline' | t }}</p>
      <div class="footer-social">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">{% render 'svg-icons', icon: 'instagram' %}</a>
        {%- endif -%}
        {%- if settings.social_tiktok != blank -%}
          <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="TikTok">{% render 'svg-icons', icon: 'tiktok' %}</a>
        {%- endif -%}
        {%- if settings.social_youtube != blank -%}
          <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="YouTube">{% render 'svg-icons', icon: 'youtube' %}</a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Footer Links {%- endcomment -%}
    <div class="footer-links">
      {%- for block in section.blocks -%}
        <div class="footer-column" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading }}</h3>
          {%- assign menu = block.settings.menu -%}
          {%- for link in linklists[menu].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="footer-bottom container">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ 'footer.copyright' | t }}</p>
    <div class="footer-bottom-links">
      <a href="/policies/privacy-policy">{{ 'footer.privacy' | t }}</a>
      <a href="/policies/terms-of-service">{{ 'footer.terms' | t }}</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_column",
      "name": "Kolom Link",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Judul Kolom",
          "default": "Link"
        },
        {
          "type": "text",
          "id": "menu",
          "label": "Handle Menu",
          "default": "footer",
          "info": "Masukkan handle menu yang dibuat di Shopify Admin > Navigation"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_column", "settings": { "heading": "Produk", "menu": "footer-produk" } },
      { "type": "link_column", "settings": { "heading": "Layanan", "menu": "footer-layanan" } },
      { "type": "link_column", "settings": { "heading": "Marketplace", "menu": "footer-marketplace" } }
    ]
  }
}
{% endschema %}
