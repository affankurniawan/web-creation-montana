<footer class="footer bg-black">
  <div class="container footer-container">
    {%- comment -%} Brand + Social {%- endcomment -%}
    <div class="footer-brand">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: height: 40 }}" alt="{{ shop.name }}" style="height:40px">
      {%- else -%}
        <img src="{{ 'logo.png' | asset_url }}" alt="Montana" style="height:40px">
      {%- endif -%}
      <p>{{ 'footer.tagline' | t }}</p>
      <div class="footer-social">
        <a href="{{ settings.social_instagram | default: 'https://www.instagram.com/montanaofficial' }}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">{% render 'svg-icons', icon: 'instagram' %}</a>
        <a href="{{ settings.social_tiktok | default: 'https://www.tiktok.com/@montanaofficial' }}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="TikTok">{% render 'svg-icons', icon: 'tiktok' %}</a>
        <a href="{{ settings.social_youtube | default: 'https://www.youtube.com/@montanaofficial' }}" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="YouTube">{% render 'svg-icons', icon: 'youtube' %}</a>
      </div>
    </div>

    {%- comment -%} Footer Links {%- endcomment -%}
    <div class="footer-links">
      {%- comment -%} Produk Column {%- endcomment -%}
      <div class="footer-column">
        <h3>Produk</h3>
        <a href="/collections/all">Katalog Produk</a>
        <a href="/pages/tentang-kami">Tentang Montana</a>
        <a href="/blogs/news">Blog</a>
      </div>

      {%- comment -%} Layanan Column {%- endcomment -%}
      <div class="footer-column">
        <h3>Layanan</h3>
        <a href="/pages/hubungi-kami">Hubungi Kami</a>
        <a href="https://wa.me/{{ settings.whatsapp_number | default: '6281234567890' }}" target="_blank" rel="noopener noreferrer">Pesanan Grosir</a>
      </div>

      {%- comment -%} Marketplace Column {%- endcomment -%}
      <div class="footer-column">
        <h3>Marketplace</h3>
        <a href="{{ settings.shopee_url | default: 'https://shopee.co.id/montanaofficial' }}" target="_blank" rel="noopener noreferrer">Shopee</a>
        <a href="{{ settings.tokopedia_url | default: 'https://www.tokopedia.com/montanaofficial' }}" target="_blank" rel="noopener noreferrer">Tokopedia</a>
        <a href="{{ settings.tiktok_url | default: 'https://shop.tiktok.com/montanaofficial' }}" target="_blank" rel="noopener noreferrer">TikTok Shop</a>
        <a href="{{ settings.lazada_url | default: 'https://www.lazada.co.id/shop/montanaofficial' }}" target="_blank" rel="noopener noreferrer">Lazada</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom container">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ 'footer.copyright' | t }}</p>
    <div class="footer-bottom-links">
      <a href="/policies/privacy-policy">{{ 'footer.privacy' | t }}</a>
      <a href="/policies/terms-of-service">{{ 'footer.terms' | t }}</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer"
}
{% endschema %}
