<section class="section-sm bg-white border-y overflow-hidden">
  <div class="container">
    <h3 class="text-center mb-3 text-gray-500" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:3px;font-weight:600">{{ section.settings.heading }}</h3>
  </div>
  <div class="logo-ticker">
    <div class="logo-track">
      {%- for block in section.blocks -%}
        <div class="client-logo-placeholder" {{ block.shopify_attributes }}>
          {%- if block.settings.logo != blank -%}
            <img src="{{ block.settings.logo | image_url: height: 50 }}" alt="{{ block.settings.name }}" style="height:50px">
          {%- else -%}
            <span>{{ block.settings.name }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
      {%- comment -%} Duplicate for infinite scroll {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="client-logo-placeholder">
          {%- if block.settings.logo != blank -%}
            <img src="{{ block.settings.logo | image_url: height: 50 }}" alt="{{ block.settings.name }}" style="height:50px">
          {%- else -%}
            <span>{{ block.settings.name }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Logo Ticker",
  "settings": [
    { "type": "text", "id": "heading", "label": "Judul", "default": "Telah Dipercaya Oleh" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "text", "id": "name", "label": "Nama", "default": "Perusahaan" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "logo", "settings": { "name": "Perusahaan 1" } },
      { "type": "logo", "settings": { "name": "Perusahaan 2" } },
      { "type": "logo", "settings": { "name": "Perusahaan 3" } },
      { "type": "logo", "settings": { "name": "Perusahaan 4" } },
      { "type": "logo", "settings": { "name": "Perusahaan 5" } },
      { "type": "logo", "settings": { "name": "Perusahaan 6" } }
    ]
  }
}
{% endschema %}
