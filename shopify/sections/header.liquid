<header class="header" data-header>
  <div class="container header-container">

    {%- comment -%} Mobile Menu Button {%- endcomment -%}
    <button class="mobile-menu-btn" aria-label="{{ 'general.menu' | t }}" aria-expanded="false">
      <span class="menu-icon">{% render 'svg-icons', icon: 'menu' %}</span>
      <span class="close-icon" style="display:none">{% render 'svg-icons', icon: 'x' %}</span>
    </button>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="logo">
      <a href="/">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: height: settings.logo_height }}" alt="{{ shop.name }}" class="header-logo" height="{{ settings.logo_height }}">
        {%- else -%}
          <img src="{{ 'logo.png' | asset_url }}" alt="Montana" class="header-logo" height="36">
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <nav class="desktop-nav">
      {%- assign menu = linklists[section.settings.menu] -%}
      {%- if menu.links.size > 0 -%}
        {%- for link in menu.links -%}
          <a href="{{ link.url }}" class="{% if link.active %}active{% endif %}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/" class="{% if request.path == '/' %}active{% endif %}">Beranda</a>
        <a href="/pages/tentang-kami" class="{% if request.path contains 'tentang' %}active{% endif %}">Tentang Kami</a>
        <a href="/collections/all" class="{% if request.path contains 'collections' %}active{% endif %}">Katalog Produk</a>
        <a href="/blogs/news" class="{% if request.path contains 'blog' %}active{% endif %}">Blog</a>
        <a href="/pages/hubungi-kami" class="{% if request.path contains 'hubungi' or request.path contains 'contact' %}active{% endif %}">Hubungi Kami</a>
      {%- endif -%}
    </nav>

    {%- comment -%} Actions {%- endcomment -%}
    <div class="header-actions">
      <button class="icon-btn search-toggle-btn" aria-label="{{ 'general.search' | t }}">
        {% render 'svg-icons', icon: 'search' %}
      </button>
      <button class="icon-btn cart-btn" data-cart-toggle aria-label="{{ 'general.cart' | t }}">
        {% render 'svg-icons', icon: 'cart' %}
        <span class="cart-badge" {% if cart.item_count == 0 %}style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>

  </div>

  {%- comment -%} Search Overlay {%- endcomment -%}
  <div class="search-overlay">
    <div class="container">
      <div class="search-input-wrapper">
        <span class="search-overlay-icon">{% render 'svg-icons', icon: 'search', size: 18 %}</span>
        <form action="/search" method="get" role="search">
          <input type="text" name="q" placeholder="{{ 'general.search_placeholder' | t }}" autocomplete="off">
        </form>
      </div>
      <div class="search-results">
        <ul>
          <li><a href="/collections/all" style="display:flex;justify-content:space-between;align-items:center;width:100%;text-decoration:none"><span class="result-title">Katalog Produk</span><span class="result-type">Jelajahi</span></a></li>
          <li><a href="/pages/hubungi-kami" style="display:flex;justify-content:space-between;align-items:center;width:100%;text-decoration:none"><span class="result-title">Pesanan Grosir via WhatsApp</span><span class="result-type">Layanan</span></a></li>
          <li><a href="/pages/tentang-kami" style="display:flex;justify-content:space-between;align-items:center;width:100%;text-decoration:none"><span class="result-title">Tentang Montana</span><span class="result-type">Informasi</span></a></li>
          <li><a href="/blogs/news" style="display:flex;justify-content:space-between;align-items:center;width:100%;text-decoration:none"><span class="result-title">Blog</span><span class="result-type">Halaman</span></a></li>
        </ul>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu Navigasi",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
