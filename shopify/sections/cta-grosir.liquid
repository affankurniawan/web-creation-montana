<section class="section text-center cta-section cta-grosir">
  <div class="container">
    <h2 class="text-white mb-2">{{ section.settings.heading }}</h2>
    <p class="text-gray-500 max-w-600 mx-auto mb-4">{{ section.settings.description }}</p>
    <a href="{{ section.settings.cta_url | default: '/pages/hubungi-kami' }}" class="btn btn-primary btn-lg">
      {{ section.settings.cta_text }}
      {% render 'svg-icons', icon: 'arrow-right', size: 18 %}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "CTA Grosir",
  "settings": [
    { "type": "text", "id": "heading", "label": "Judul", "default": "Pesanan Grosir & Kemitraan Ritel" },
    { "type": "textarea", "id": "description", "label": "Deskripsi", "default": "Sediakan Montana di toko Anda atau lengkapi seluruh kantor Anda dengan nilai yang cerdas." },
    { "type": "text", "id": "cta_text", "label": "Teks Tombol", "default": "Hubungi Kami" },
    { "type": "text", "id": "cta_url", "label": "URL Tombol", "default": "/pages/contact" }
  ],
  "presets": [{ "name": "CTA Grosir" }]
}
{% endschema %}
